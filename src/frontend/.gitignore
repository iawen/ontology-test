node_modules/
jspm_packages/

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 运行时数据
pids/
*.pid
*.seed
*.pid.lock

# 环境变量文件
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# 构建产物
dist/
build/
out/
.next/
.nuxt/
.cache/

# 临时文件
*.tmp
*.temp
.cache/

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 测试覆盖率
coverage/
